# Node environment (development | production | test)
# NODE_ENV=development

# Server
SERVER_PORT=5500

# Client
CLIENT_PROTOCOL=http
CLIENT_HOST=localhost
# CLIENT_PORT=0

# RSS feed (optional - defaults to CLIENT_URL if not set)
# BASE_URL=
# BLOG_TITLE=pyosh blog
# BLOG_DESCRIPTION=Pyosh 개발 블로그의 최신 글을 제공합니다.

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=pyosh
DB_PSWD=change-me
DB_DTBS=pyosh_blog

# Session
SESSION_SECRET=replace-with-long-random-string
# SESSION_COOKIE_DOMAIN=.pyosh.com

# OAuth redirects
LOGIN_SUCCESS_PATH=/auth/success
LOGIN_FAILURE_PATH=/auth/failure

# Google OAuth
GOOGLE_CLIENT_ID=google-client-id
GOOGLE_CLIENT_SECRET=google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=github-client-id
GITHUB_CLIENT_SECRET=github-client-secret
